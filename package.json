{
  "name": "@crouton-kit/capture",
  "version": "1.3.6",
  "description": "Browser automation and UI validation via CDP — session-based screenshots, HAR, a11y, click/type, and JS exec",
  "bin": {
    "capture": "./bin/capture"
  },
  "files": [
    "bin",
    "src"
  ],
  "scripts": {
    "build": "esbuild src/capture.ts --bundle --platform=node --format=cjs --outfile=bin/capture --external:esbuild '--banner:js=#!/usr/bin/env node' \"--define:globalThis.__CAPTURE_VERSION__=\\\"$npm_package_version\\\"\" && chmod +x bin/capture",
    "dev": "tsx src/capture.ts",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CaptainCrouton89/capture.git"
  },
  "keywords": [
    "cdp",
    "chrome-devtools-protocol",
    "browser-automation",
    "har",
    "screenshot",
    "accessibility",
    "a11y",
    "testing"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.24.0",
    "tsx": "^4",
    "typescript": "^5.7.0",
    "zod": "^4.3.5"
  },
  "dependencies": {
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0",
    "ws": "^8.19.0"
  }
}
