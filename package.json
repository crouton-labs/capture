{
  "name": "@crouton-kit/capture",
  "version": "1.3.13",
  "description": "Browser automation and UI validation via CDP — session-based screenshots, HAR, a11y, click/type, and JS exec",
  "bin": {
    "capture": "./bin/capture"
  },
  "files": [
    "bin",
    "src"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "check:bin": "node scripts/build.mjs --check",
    "dev": "tsx src/capture.ts",
    "test": "node scripts/test.mjs",
    "test:live": "node scripts/test.mjs --live",
    "test:install-chrome": "npx --yes @puppeteer/browsers install chrome-headless-shell@143.0.7499.40"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CaptainCrouton89/capture.git"
  },
  "keywords": [
    "cdp",
    "chrome-devtools-protocol",
    "browser-automation",
    "har",
    "screenshot",
    "accessibility",
    "a11y",
    "testing"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.24.0",
    "tsx": "^4",
    "typescript": "^5.7.0",
    "zod": "^4.3.5"
  },
  "dependencies": {
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0",
    "ws": "^8.19.0"
  }
}
